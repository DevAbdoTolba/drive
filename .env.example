# Copy this file to .env before starting. Replace every CHANGE_ME value.

# Use an IANA timezone, for example Africa/Cairo or Europe/London.
TZ=Africa/Cairo

# Set this to the computer's fixed home-LAN IPv4 address.
# Do not use 0.0.0.0: it also binds VPN and other network adapters.
LAN_BIND_ADDRESS=192.168.1.50
NEXTCLOUD_PORT=8080
IMMICH_PORT=2283

# Include localhost and this computer's current LAN IPv4 address.
# Entries are separated by spaces. Do not include http:// or a path.
NEXTCLOUD_TRUSTED_DOMAINS=localhost 127.0.0.1 CHANGE_ME_LAN_IP

# Used only during the first Nextcloud installation.
NEXTCLOUD_ADMIN_USER=family-admin
NEXTCLOUD_ADMIN_PASSWORD=CHANGE_ME_NEXTCLOUD_ADMIN_PASSWORD

NEXTCLOUD_DB_NAME=nextcloud
NEXTCLOUD_DB_USER=nextcloud
NEXTCLOUD_DB_PASSWORD=CHANGE_ME_NEXTCLOUD_DATABASE_PASSWORD
NEXTCLOUD_DB_ROOT_PASSWORD=CHANGE_ME_NEXTCLOUD_DATABASE_ROOT_PASSWORD
NEXTCLOUD_UPLOAD_LIMIT=10G

# Keep this pinned until following Immich's upgrade notes.
IMMICH_VERSION=v3.0.3
IMMICH_DB_NAME=immich
IMMICH_DB_USER=postgres
# Immich requires only A-Z, a-z and 0-9 in this password.
IMMICH_DB_PASSWORD=CHANGE_ME_IMMICH_DATABASE_PASSWORD
IMMICH_MEDIA_PATH=./storage/immich/library
# Change to false after the first Immich admin account has been created.
IMMICH_ALLOW_SETUP=true
